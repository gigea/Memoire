{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Linux Screen Recorder",
            "type": "shell",
            "command": "/bin/bash",
            "args": [
                "-lc",
                "g++ ScreenRecorderCommon.cpp ScreenRecorderLinux.cpp -lX11 -lXrandr $(pkg-config --cflags --libs gtk+-3.0) -o ${workspaceFolder}/screen_recorder_linux"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
